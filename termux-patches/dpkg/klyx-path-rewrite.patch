diff --git a/lib/dpkg/tarfn.c b/lib/dpkg/tarfn.c
index 48e3c384a..c3b168f62 100644
--- a/lib/dpkg/tarfn.c
+++ b/lib/dpkg/tarfn.c
@@ -449,6 +449,111 @@ tar_entry_update_from_system(struct tar_entry *te)
 	}
 }
 
+/*
+ * klyx: when TERMUX_APP__PACKAGE_NAME is set in the environment
+ * and differs from the upstream "com.termux" baked into Termux's prebuilt
+ * .debs, rewrite tar entry paths starting with "data/data/com.termux"
+ * (followed by either "/..." OR end-of-string — see boundary check below)
+ * to "data/data/<env>/..." at extract time. Lets a fork install upstream
+ * Termux packages without rebuilding each one for the new prefix. No-op
+ * when the env var is unset or equals "com.termux".
+ *
+ * Variable name uses Termux's double-underscore convention, same as
+ * scripts/build-bootstraps.sh:246 and scripts/build/termux_download_deb_pac.sh
+ * already use for this concept.
+ *
+ * Three lead forms accepted (file paths inside data.tar are typically
+ * relative, while symlink targets are absolute):
+ *   - "data/data/com.termux/..."
+ *   - "./data/data/com.termux/..."
+ *   - "/data/data/com.termux/..."
+ *
+ * Boundary rule (extended 2026-05-06 after `apt install patchelf` failed
+ * with `unable to stat './data/data/com.termux' (which was about to be
+ * installed): Permission denied`): the byte after the 20-char base
+ * "data/data/com.termux" must be exactly '/' (regular file/dir entries)
+ * or '\0' (the bare-directory marker some tar implementations emit
+ * without a trailing slash for the package's own data dir). MUST NOT
+ * match a sibling like "data/data/com.termuxblah/..." — that would be
+ * a different package whose name happens to share a prefix.
+ */
+static void
+tarfn_translate_termux_path(char **name_ptr)
+{
+	static char *target;
+	static int initialized;
+	static const char base[] = "data/data/com.termux";
+	const size_t base_len = sizeof(base) - 1;
+	const char *name;
+	const char *prefix;
+	char boundary;
+	size_t lead;
+	size_t target_len;
+	const char *rest;
+	size_t rest_len;
+	size_t new_len;
+	char *new_name;
+	char *out;
+
+	if (!initialized) {
+		const char *env = getenv("TERMUX_APP__PACKAGE_NAME");
+		if (env != NULL && env[0] != '\0' &&
+		    strcmp(env, "com.termux") != 0)
+			target = m_strdup(env);
+		initialized = 1;
+	}
+	if (target == NULL || name_ptr == NULL || *name_ptr == NULL)
+		return;
+
+	name = *name_ptr;
+	prefix = name;
+	lead = 0;
+	if (prefix[0] == '.' && prefix[1] == '/') {
+		prefix += 2;
+		lead = 2;
+	} else if (prefix[0] == '/') {
+		prefix += 1;
+		lead = 1;
+	}
+	if (strncmp(prefix, base, base_len) != 0)
+		return;
+	boundary = prefix[base_len];
+	/* Must terminate cleanly at "/" or end-of-string. Anything else
+	 * (e.g. "data/data/com.termuxblah/...") is a different package
+	 * whose name happens to share a prefix; do not rewrite. */
+	if (boundary != '/' && boundary != '\0')
+		return;
+
+	target_len = strlen(target);
+	if (boundary == '/') {
+		rest = prefix + base_len; /* keeps the leading '/' */
+		rest_len = strlen(rest);
+	} else {
+		rest = "";
+		rest_len = 0;
+	}
+	new_len = lead + 10 /* "data/data/" */ + target_len + rest_len + 1;
+	new_name = m_malloc(new_len);
+
+	out = new_name;
+	if (lead > 0) {
+		memcpy(out, name, lead);
+		out += lead;
+	}
+	memcpy(out, "data/data/", 10);
+	out += 10;
+	memcpy(out, target, target_len);
+	out += target_len;
+	if (rest_len > 0) {
+		memcpy(out, rest, rest_len);
+		out += rest_len;
+	}
+	*out = '\0';
+
+	free(*name_ptr);
+	*name_ptr = new_name;
+}
+
 int
 tar_extractor(struct tar_archive *tar)
 {
@@ -501,6 +606,11 @@ tar_extractor(struct tar_archive *tar)
 			next_long_name = NULL;
 		}
 
+		if (h.type != TAR_FILETYPE_GNU_LONGLINK && h.type != TAR_FILETYPE_GNU_LONGNAME) {
+			tarfn_translate_termux_path(&h.name);
+			tarfn_translate_termux_path(&h.linkname);
+		}
+
 		if (h.name[0] == '\0') {
 			status = dpkg_put_error(&tar->err,
 			                        _("invalid tar header with empty name field"));
diff --git a/src/deb/extract.c b/src/deb/extract.c
index 8b78a7eab..336b496e1 100644
--- a/src/deb/extract.c
+++ b/src/deb/extract.c
@@ -103,6 +103,50 @@ read_line(int fd, char *buf, size_t min_size, size_t max_size)
   return line_size;
 }
 
+/*
+ * klyx companion to lib/dpkg/tarfn.c's
+ * tarfn_translate_termux_path. libdpkg's tar_extractor handles the
+ * `dpkg --unpack` / `apt install` path; this helper handles
+ * `dpkg-deb -x | -X | --raw-extract`, which forks GNU tar directly.
+ *
+ * When TERMUX_APP__PACKAGE_NAME is set and != "com.termux", returns a
+ * sed expression suitable for `tar --transform=EXPR`. The expression
+ * rewrites tar entry names whose paths begin with "data/data/com.termux/"
+ * — including symlink targets and hardlink targets via the "Srh" flags.
+ *
+ * Three lead forms covered (matches the libdpkg-side patch exactly):
+ *   - "data/data/com.termux/..."
+ *   - "./data/data/com.termux/..."
+ *   - "/data/data/com.termux/..."
+ *
+ * Returns NULL when env unset / equals "com.termux".
+ */
+static const char *
+tarfn_get_termux_transform(void)
+{
+  static char *expr;
+  static int initialized;
+
+  if (!initialized) {
+    const char *env = getenv("TERMUX_APP__PACKAGE_NAME");
+    if (env != NULL && env[0] != '\0' &&
+        strcmp(env, "com.termux") != 0)
+      /* Matches "data/data/com.termux" followed by either "/" (regular
+       * file/dir entries) OR end-of-string (the bare-directory marker
+       * tar implementations emit without trailing "/"). The boundary
+       * group \\(/\\|$\\) is captured in \\2 and re-emitted so a
+       * trailing-slashed entry round-trips trailing-slashed and a
+       * bare-dir entry stays bare. Boundary check parallels the
+       * lib/dpkg/tarfn.c patch — see comments there. */
+      expr = str_fmt(
+          "s,^\\(/\\|\\./\\)\\?"
+          "data/data/com\\.termux\\(/\\|$\\),"
+          "\\1data/data/%s\\2,Srh", env);
+    initialized = 1;
+  }
+  return expr;
+}
+
 void
 extracthalf(const char *debar, const char *dir,
             enum dpkg_tar_options taroption, int admininfo)
@@ -339,6 +383,13 @@ extracthalf(const char *debar, const char *dir,
       command_add_arg(&cmd, "-f");
       command_add_arg(&cmd, "-");
       command_add_arg(&cmd, "--warning=no-timestamp");
+      if (taroption & DPKG_TAR_EXTRACT) {
+        const char *transform = tarfn_get_termux_transform();
+        if (transform != NULL) {
+          command_add_arg(&cmd, "--transform");
+          command_add_arg(&cmd, transform);
+        }
+      }
 
       m_dup2(p2[0],0);
       close(p2[0]);
