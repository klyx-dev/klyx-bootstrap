# The patched dpkg + dpkg-deb shipped in our bootstrap
# have `com.termux` → our-package-name path rewriting in lib/dpkg/tarfn.c and
# src/deb/extract.c. Upstream's binaries don't, and replacing
# ours with theirs bricks the whole package manager (RUNPATH,
# sysconfdir, info-dir all baked to com.klyx). Forbid the
# upgrade.
Package: dpkg
Pin: release *
Pin-Priority: 1001

# patchelf is load-bearing for the 98-klyx-patchelf Post-Invoke
# hook. Without it, freshly-installed ELFs have wrong RUNPATH
# and fail at dlopen. apt autoremove was observed dropping it
# mid-session (2026-05-06 openssh install). Pin keeps it.
Package: patchelf
Pin: release *
Pin-Priority: 1001
